rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Preview images and print files are publicly readable.
    // Paths are UUIDs so they are not enumerable.
    // Writes are server-only (Cloud Function uses Admin SDK, bypasses rules).
    match /previews/{file} {
      allow read: if true;
      allow write: if false;
    }

    match /print_files/{file} {
      allow read: if true;
      allow write: if false;
    }

    // All other paths require authentication.
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}

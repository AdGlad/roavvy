rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────

    function isOwnUser(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // ── User subcollections ──────────────────────────────────────────────────
    //
    // NOTE: The former wildcard match /users/{userId}/{document=**} has been
    // replaced with explicit per-subcollection rules so that the field allowlist
    // on inferred_visits is actually enforced (ADR-002, T6.5).
    // Firestore rule evaluation is OR-based: a write is allowed if ANY matching
    // rule allows it, so a wildcard would bypass the field restriction on
    // inferred_visits regardless of the more specific rule below.

    // inferred_visits: strict field allowlist (ADR-002 — no GPS or photo data).
    // Permitted fields: inferredAt, photoCount, firstSeen, lastSeen, syncedAt.
    match /users/{userId}/inferred_visits/{country} {
      allow read: if isOwnUser(userId);
      allow write: if isOwnUser(userId)
          && request.resource.data.keys().hasOnly(
              ['inferredAt', 'photoCount', 'firstSeen', 'lastSeen', 'syncedAt']);
    }

    // user_added: manual country additions.
    match /users/{userId}/user_added/{country} {
      allow read, write: if isOwnUser(userId);
    }

    // user_removed: manual country removals (tombstones).
    match /users/{userId}/user_removed/{country} {
      allow read, write: if isOwnUser(userId);
    }

    // unlocked_achievements: achievement unlock sync.
    match /users/{userId}/unlocked_achievements/{achievementId} {
      allow read, write: if isOwnUser(userId);
    }

    // trips: trip-level sync (M30, ADR-003).
    match /users/{userId}/trips/{tripId} {
      allow read, write: if isOwnUser(userId);
    }

    // travel_cards: shareable card data.
    match /users/{userId}/travel_cards/{cardId} {
      allow read, write: if isOwnUser(userId);
    }

    // artwork_confirmations: artwork approval records.
    match /users/{userId}/artwork_confirmations/{confirmationId} {
      allow read, write: if isOwnUser(userId);
    }

    // mockup_approvals: merch mockup approval records.
    match /users/{userId}/mockup_approvals/{approvalId} {
      allow read, write: if isOwnUser(userId);
    }

    // merch_configs: merch configuration written by Cloud Functions and client.
    match /users/{userId}/merch_configs/{configId} {
      allow read, write: if isOwnUser(userId);
    }

    // cartItems: client-side merch cart items (M120).
    match /users/{userId}/cartItems/{itemId} {
      allow read, write: if isOwnUser(userId);
    }

    // ── Top-level collections ─────────────────────────────────────────────────

    // Daily Heritage Challenge documents (M133).
    // Written exclusively by the Admin SDK (Cloud Function). All authenticated
    // users may read any date's document so clues are the same for everyone.
    match /daily_challenge/{date} {
      allow read: if request.auth != null;
    }

    // Public travel share cards (ADR-041, ADR-043).
    // Anyone may read a share card; only the owning user may create, update,
    // or delete it. Delete uses resource.data.uid (the existing document)
    // because request.resource is null on delete operations.
    match /sharedTravelCards/{token} {
      allow read: if true;
      allow create, update: if request.auth != null
          && request.auth.uid == request.resource.data.uid;
      allow delete: if request.auth != null
          && request.auth.uid == resource.data.uid;
    }
  }
}

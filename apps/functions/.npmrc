# Force linux/amd64 native module binaries for Cloud Run compatibility.
# Cloud Run uses linux/amd64; development machines may be darwin/arm64.
# Without this, @resvg/resvg-js and sharp download arm64 binaries that
# fail to load in Cloud Run with "invalid ELF header" or "Module did not
# self-register".
#
# Trade-off: native modules cannot run locally on Apple Silicon without
# Rosetta or Docker. Unit tests must mock @resvg/resvg-js and sharp
# (see src/__mocks__/ and jest moduleNameMapper in package.json).
platform=linux
arch=x64
libc=glibc

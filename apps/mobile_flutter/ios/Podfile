source 'https://github.com/CocoaPods/Specs.git'
platform :ios, '13.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks! :linkage => :static

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'
    end
  end

  # Re-sign frameworks embedded by Flutter's Native Assets pipeline.
  #
  # Flutter Native Assets (used by the sqlite3 package) produces frameworks
  # that are initially ad-hoc signed (no Team ID). When the app is installed
  # on a real device iOS rejects them with error 0xe8008014.
  #
  # This block adds a Run Script build phase to Runner.xcodeproj (once) that
  # re-signs every .framework inside the app bundle using the app's own
  # code-signing identity, immediately after Flutter embeds them.
  require 'xcodeproj'
  project_path = File.expand_path('../Runner.xcodeproj', __FILE__)
  project = Xcodeproj::Project.open(project_path)

  project.targets.each do |target|
    next unless target.name == 'Runner'
    next if target.shell_script_build_phases.any? { |p| p.name == 'Re-sign Embedded Frameworks' }

    phase = target.new_shell_script_build_phase('Re-sign Embedded Frameworks')
    phase.shell_script = <<~SHELL
      # Re-sign frameworks embedded by Flutter Native Assets (e.g. sqlite3.framework).
      # Fixes error 0xe8008014 ("invalid signature") on real-device installs.
      FRAMEWORKS="${CODESIGNING_FOLDER_PATH}/Frameworks"
      if [ -d "${FRAMEWORKS}" ] && [ "${CODE_SIGNING_REQUIRED}" = "YES" ]; then
        find "${FRAMEWORKS}" -maxdepth 1 -name "*.framework" | while read FW; do
          codesign --force --sign "${EXPANDED_CODE_SIGN_IDENTITY}" \
            --preserve-metadata=identifier,entitlements "${FW}" || true
        done
      fi
    SHELL
  end

  # Generate sqlite3.framework.dSYM for App Store Connect symbol upload.
  # Flutter's Native Assets pipeline builds sqlite3 with embedded debug symbols;
  # this extracts them into a separate dSYM bundle at archive time so the
  # upload tool can find them.
  project.targets.each do |target|
    next unless target.name == 'Runner'
    # Remove stale version so the script below is always kept up to date
    target.shell_script_build_phases.select { |p| p.name == 'Generate sqlite3 dSYM' }.each(&:remove_from_project)

    phase = target.new_shell_script_build_phase('Generate sqlite3 dSYM')
    phase.shell_script = <<~SHELL
      # Generate sqlite3.framework.dSYM for App Store Connect symbol upload.
      # Flutter Native Assets embeds sqlite3 inside the app bundle; this script
      # locates it and produces the dSYM the upload tool requires.
      OUT="${DWARF_DSYM_FOLDER_PATH}/sqlite3.framework.dSYM"
      [ -d "${OUT}" ] && exit 0          # already present
      [ -z "${DWARF_DSYM_FOLDER_PATH}" ] && exit 0  # not archiving

      # 1. Copy a pre-built dSYM if the build system already produced one
      for DIR in \
        "${BUILT_PRODUCTS_DIR}" \
        "${BUILD_DIR}/${CONFIGURATION}-iphoneos" \
        "${OBJROOT}/UninstalledProducts/iphoneos"; do
        SRC="${DIR}/sqlite3.framework.dSYM"
        if [ -d "${SRC}" ]; then
          cp -R "${SRC}" "${OUT}" && exit 0
        fi
      done

      # 2. Extract from the embedded binary (dwarf format – symbols still inside)
      for FW in \
        "${CODESIGNING_FOLDER_PATH}/Frameworks/sqlite3.framework/sqlite3" \
        "${BUILT_PRODUCTS_DIR}/sqlite3.framework/sqlite3"; do
        if [ -f "${FW}" ]; then
          xcrun dsymutil "${FW}" -o "${OUT}" 2>/dev/null && exit 0
        fi
      done

      echo "warning: sqlite3.framework dSYM could not be generated; App Store symbol upload may warn"
    SHELL
  end

  project.save
end

<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>Roavvy</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>Roavvy</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>NSBonjourServices</key>
	<array>
		<string>_dartobservatory._tcp</string>
		<string>_dart._tcp</string>
	</array>
	<key>NSLocalNetworkUsageDescription</key>
	<string>Allow local network access for Flutter DevTools debugging.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Roavvy reads the location and date from your photos to detect which countries you've visited. Your photos never leave your device.</string>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<!-- URL schemes for OAuth providers. Fill in values from Firebase Console /
	     Meta Developer Portal after enabling each sign-in method. -->
	<key>CFBundleURLTypes</key>
	<array>
		<!-- Google Sign-In: REVERSED_CLIENT_ID from GoogleService-Info.plist
		     (present after enabling Google Sign-In in Firebase Console). -->
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>REPLACE_WITH_REVERSED_CLIENT_ID</string>
			</array>
		</dict>
		<!-- Facebook Sign-In: fb{APP_ID} from Meta Developer Portal. -->
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>fbREPLACE_WITH_FACEBOOK_APP_ID</string>
			</array>
		</dict>
	</array>
	<!-- Facebook SDK configuration. Fill in after creating app in Meta Developer Portal. -->
	<key>FacebookAppID</key>
	<string>REPLACE_WITH_FACEBOOK_APP_ID</string>
	<key>FacebookClientToken</key>
	<string>REPLACE_WITH_FACEBOOK_CLIENT_TOKEN</string>
	<key>FacebookDisplayName</key>
	<string>Roavvy</string>
	<!-- Required so the Facebook SDK can check if the FB app is installed. -->
	<key>LSApplicationQueriesSchemes</key>
	<array>
		<string>fbapi</string>
		<string>fb-messenger-share-api</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>

</dict>
</plist>
